# Copy this file to .env and fill in your values

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=smart_attendance

# JWT — change SECRET_KEY in production! Minimum 32 characters.
SECRET_KEY=your-super-secret-key-please-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
DEBUG=True
