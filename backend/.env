# Smart Attendance System — Environment Configuration
# Copy this to .env and fill in your values

# ── MongoDB ────────────────────────────────────────────────
# Local:  MONGO_URI=mongodb://localhost:27017
# Atlas:  MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
DB_NAME=smart_attendance

# ── JWT Auth ───────────────────────────────────────────────
# IMPORTANT: Change SECRET_KEY in production!
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-strong-random-key-here-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── QR Attendance ──────────────────────────────────────────
QR_SECRET_KEY=qr-specific-secret-key-also-change-in-production
QR_EXPIRE_MINUTES=5

# ── CORS ───────────────────────────────────────────────────
# Add your frontend URL(s) here
# ALLOWED_ORIGINS=["http://localhost:5173","https://yourdomain.com"]

# ── App ────────────────────────────────────────────────────
DEBUG=True
